{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  },
  "include": ["app", "components", "hooks", "lib", "pages", "tests"]
}
