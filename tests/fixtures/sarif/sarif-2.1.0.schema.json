{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SARIF 2.1.0 (CodeScent vendored structural subset)",
  "description": "Faithful subset of the OASIS SARIF 2.1.0 schema covering the required sarifLog/run/tool/result structure CodeScent emits. Anything valid under this schema is structurally valid SARIF 2.1.0. Vendored so validation runs offline with no network fetch.",
  "type": "object",
  "required": ["version", "runs"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "2.1.0" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "results"],
        "properties": {
          "tool": {
            "type": "object",
            "required": ["driver"],
            "properties": {
              "driver": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "rules": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id"],
                      "properties": {
                        "id": { "type": "string" },
                        "name": { "type": "string" },
                        "shortDescription": {
                          "type": "object",
                          "required": ["text"],
                          "properties": { "text": { "type": "string" } }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["message", "locations"],
              "properties": {
                "ruleId": { "type": "string" },
                "ruleIndex": { "type": "integer", "minimum": 0 },
                "level": { "enum": ["none", "note", "warning", "error"] },
                "message": {
                  "type": "object",
                  "required": ["text"],
                  "properties": { "text": { "type": "string" } }
                },
                "partialFingerprints": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "locations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["physicalLocation"],
                    "properties": {
                      "physicalLocation": {
                        "type": "object",
                        "required": ["artifactLocation"],
                        "properties": {
                          "artifactLocation": {
                            "type": "object",
                            "required": ["uri"],
                            "properties": { "uri": { "type": "string" } }
                          },
                          "region": {
                            "type": "object",
                            "required": ["startLine"],
                            "properties": {
                              "startLine": { "type": "integer", "minimum": 1 },
                              "endLine": { "type": "integer", "minimum": 1 }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
